module median_testbench ();
 reg [7:0] p1,p2,p3,p4,p5,p6,p7,p8,p9;
 wire [7:0] med;
 reg [0:4095] image ;
 integer file,i,j;
median_filter_3x3 duut (.p1(p1),.p2(p2),.p3(p3),.p4(p4),.p5(p5),.p6(p6),.p7(p7),.p8(p8),.p9(p9),.med(med));
 initial begin
    $readmemh("pic_input.txt",image);
 end
 initial begin 
    file=$fopen("pic_output.txt","w");
    if(!file) begin
     $display("khong the mo file");
     $finish;
    end
    for(i=1; i<63; i=i+1) begin
        for(j=1;j<63;j=j+1) begin
            p1=image[(i-1)*64 + (j-1)];
            p2=image[(i-1)*64+(j+1)];
            p3=image[(i-1)*64+j];

            p4=image[i*64+(j-1)];
            p5=image[i*64+(j+1)];
            p6=image[i*64+j];

            p7=image[(i+1)*64 + (j-1)];
            p8=image[(i+1)*64+(j+1)];
            p9=image[(i+1)*64+j];
            #10;
            $fwrite(file,"%h\n",med);
            end
    end
 end
endmodule

